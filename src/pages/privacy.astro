---
import Layout from '../layouts/Layout.astro';

const lastUpdated = '2026-03-02';

const sections = [
  {
    title: '1. Information We Collect',
    content: `When you visit hikari.to, we may collect the following types of information:`,
    items: [
      '<strong>Usage Data</strong> — anonymized analytics such as pages visited, referral source, browser type, and device information.',
      '<strong>Cookies & Local Storage</strong> — small data files used to remember your preferences (e.g., cookie consent choice).',
      '<strong>Contact Information</strong> — if you voluntarily submit a demo request or contact form, we collect the information you provide (name, email, company).',
    ],
  },
  {
    title: '2. How We Use Your Information',
    items: [
      'To operate and improve the hikari.to website.',
      'To respond to demo requests and inquiries.',
      'To understand how visitors interact with our site via aggregated analytics.',
      'To ensure the security and integrity of our services.',
    ],
  },
  {
    title: '3. Cookies',
    content: `We use a minimal set of cookies:`,
    items: [
      '<strong>Essential cookies</strong> — required for basic site functionality and your cookie consent preference.',
      '<strong>Analytics cookies</strong> — help us understand traffic patterns. These are only enabled if you accept analytics cookies.',
    ],
    afterItems: 'You can change your cookie preferences at any time by clearing your browser storage or using the cookie settings on this site.',
  },
  {
    title: '4. Data Sharing',
    content: `We do not sell your personal data. We may share information only in the following circumstances:`,
    items: [
      'With service providers that help us operate our website (e.g., hosting, analytics), bound by data processing agreements.',
      'When required by law or to protect our legal rights.',
    ],
  },
  {
    title: '5. Data Retention',
    content: `We retain personal data only as long as necessary to fulfill the purposes described in this policy. Analytics data is stored in aggregated, anonymized form.`,
  },
  {
    title: '6. Your Rights',
    content: `Depending on your jurisdiction, you may have the right to:`,
    items: [
      'Access the personal data we hold about you.',
      'Request correction or deletion of your data.',
      'Object to or restrict processing of your data.',
      'Withdraw consent at any time.',
    ],
    afterItems: 'To exercise any of these rights, contact us at the address below.',
  },
  {
    title: '7. Security',
    content: `We implement industry-standard technical and organizational measures to protect your data against unauthorized access, loss, or misuse.`,
  },
  {
    title: '8. Third-Party Links',
    content: `Our site may contain links to external websites. We are not responsible for the privacy practices of third-party sites.`,
  },
  {
    title: '9. Changes to This Policy',
    content: `We may update this Privacy Policy from time to time. Changes will be posted on this page with an updated revision date.`,
  },
  {
    title: '10. Contact',
    content: `If you have questions about this Privacy Policy, please reach out via <a href="https://catdev.io" target="_blank" rel="noopener" class="text-hikari-accent hover:underline">catdev.io</a>.`,
  },
];
---

<Layout title="Privacy Policy — Hikari" description="Privacy Policy for hikari.to — learn how we handle your data.">
  <section class="py-20">
    <div class="wrap max-w-[780px]">
      <a href={`${import.meta.env.BASE_URL}`} class="inline-flex items-center gap-1.5 text-hikari-muted text-[0.82rem] hover:text-hikari-accent transition-colors duration-150 mb-8 no-underline">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="rotate-180"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Back to home
      </a>

      <span class="label">Privacy Policy</span>
      <h1 class="text-hikari-text-strong text-[1.8rem] font-semibold leading-tight mb-3">
        How we handle your data
      </h1>
      <p class="desc mb-10">
        Last updated: <time datetime={lastUpdated}>{lastUpdated}</time>
      </p>

      <div class="space-y-10">
        {sections.map((section) => (
          <div>
            <h2 class="text-hikari-text-strong text-[1.1rem] font-semibold mb-3">{section.title}</h2>
            {section.content && <p class="text-hikari-text text-[0.92rem] leading-relaxed mb-3" set:html={section.content} />}
            {section.items && (
              <ul class="space-y-2 ml-4">
                {section.items.map((item) => (
                  <li class="text-hikari-text text-[0.92rem] leading-relaxed relative pl-4 before:content-[''] before:absolute before:left-0 before:top-[0.55em] before:w-1.5 before:h-1.5 before:rounded-full before:bg-hikari-accent/40" set:html={item} />
                ))}
              </ul>
            )}
            {section.afterItems && <p class="text-hikari-muted text-[0.88rem] leading-relaxed mt-3">{section.afterItems}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
